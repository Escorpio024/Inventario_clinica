# ─────────────────────────────────────────────────────────────────────────────
# Inventario Clínica — Variables de Entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas el archivo .env a Git
# ─────────────────────────────────────────────────────────────────────────────

# ── Seguridad (OBLIGATORIO cambiar en producción) ──────────────────────────
# Genera una clave segura con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-segura-de-al-menos-32-caracteres

# ── SuperAdmin inicial (OBLIGATORIO configurar en producción) ─────────────
# Estas credenciales se usan la PRIMERA VEZ que arranca el servidor para crear el superadmin
# En Render: configúralas como Environment Variables ANTES del primer deploy
SUPERADMIN_EMAIL=admin@clinica.com
SUPERADMIN_PASSWORD=admin123
SUPERADMIN_NAME=Super Administrador

# ── Base de datos ──────────────────────────────────────────────────────────
# En local con Docker: usar los valores de abajo
# En Render: poner la DATABASE_URL completa de PostgreSQL que Render provee
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventario
DB_PORT=5432

# En Render.com (Backend Web Service), usar esta variable directamente:
# DATABASE_URL=postgresql://user:password@host/dbname

# ── API Backend ────────────────────────────────────────────────────────────
API_PORT=8000

# CORS: dominios autorizados para hacer peticiones a la API
# En producción: URL de tu frontend en Vercel, ej: https://mi-clinica.vercel.app
# Separar múltiples orígenes con coma sin espacios:
# ALLOWED_ORIGINS=https://mi-clinica.vercel.app,https://www.mi-clinica.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend Next.js ───────────────────────────────────────────────────────
WEB_PORT=3000

# URL de la API que el NAVEGADOR del cliente usará para conectarse
# En local: http://localhost:8000
# En producción (Vercel): URL pública de tu backend en Render
# Ej: https://inventario-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

